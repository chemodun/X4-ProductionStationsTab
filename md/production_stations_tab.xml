<?xml version="1.0" encoding="utf-8"?>
<mdscript name="Production_Stations_Tab" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <cues>

        <!-- ═══════════════════════════════════════════════════════════
         Default configuration + variable helpers
    ═══════════════════════════════════════════════════════════════ -->

        <!--
      Ensures player.entity.$productionStationsTab exists with all required keys.
      Call via include_actions / run_actions before reading config.
    -->
        <library name="DefaultConfig" purpose="include_actions" version="1">
            <actions>
                <do_if value="@player.entity.$productionStationsTab == null">
                    <set_value name="player.entity.$productionStationsTab" exact="table[
            $showAll                 = true,
            $filterIntNoRes          = true,
            $filterIntWaitStore      = false,
            $filterProdNoRes         = true,
            $filterProdWaitStore     = true,
            $debugLevel              = 'none'
          ]" />
                </do_if>
                <!-- Add missing keys so old saves are forward-compatible.
                     Use a local $cfg ref so we can test key existence with $cfg.$key? (which
                     cannot be combined with the @ prefix in a chain: @tbl.$key? is a parse error).
                -->
                <set_value name="$cfg" exact="player.entity.$productionStationsTab" />
                <do_if value="$cfg.$showAll? == false">
                    <set_value name="$cfg.$showAll" exact="true" />
                </do_if>
                <do_if value="$cfg.$filterIntNoRes? == false">
                    <set_value name="$cfg.$filterIntNoRes" exact="true" />
                </do_if>
                <do_if value="$cfg.$filterIntWaitStore? == false">
                    <set_value name="$cfg.$filterIntWaitStore" exact="false" />
                </do_if>
                <do_if value="$cfg.$filterProdNoRes? == false">
                    <set_value name="$cfg.$filterProdNoRes" exact="true" />
                </do_if>
                <do_if value="$cfg.$filterProdWaitStore? == false">
                    <set_value name="$cfg.$filterProdWaitStore" exact="true" />
                </do_if>
                <do_if value="$cfg.$debugLevel? == false">
                    <set_value name="$cfg.$debugLevel" exact="'none'" />
                </do_if>
                <remove_value name="$cfg" />
            </actions>
        </library>

        <!--
      Reads config into local $config variable.
      Caller must remove_value $config when done.
    -->
        <library name="Get_Variables" purpose="include_actions" version="1">
            <actions>
                <include_actions ref="DefaultConfig" />
                <set_value name="$config" exact="player.entity.$productionStationsTab" />
            </actions>
        </library>

        <!-- ═══════════════════════════════════════════════════════════
         Startup: initialise config on first load
    ═══════════════════════════════════════════════════════════════ -->

        <cue name="Main" version="1">
            <actions>
                <include_actions ref="DefaultConfig" />
            </actions>
        </cue>

        <!-- ═══════════════════════════════════════════════════════════
         Extension Options menu
    ═══════════════════════════════════════════════════════════════ -->

        <cue name="Init" instantiate="false" version="1">
            <actions>
                <set_value name="$debugChance" exact="0" />
            </actions>
            <cues>

                <cue name="Register_Menu" instantiate="true" version="1">
                    <conditions>
                        <event_cue_signalled cue="md.Simple_Menu_API.Reloaded" />
                    </conditions>
                    <actions>
                        <include_actions ref="Get_Variables" />
                        <debug_text text="'ProductionStationsTab Options: Registering Options Menu'" chance="$debugChance" filter="scripts" />
                        <signal_cue_instantly cue="md.Simple_Menu_API.Register_Options_Menu"
                            param="table[
                $id      = 'production_stations_tab_options_menu',
                $columns = 12,
                $title   = {1972092418, 10000},
                $onOpen  = Open_Options_Menu,
              ]" />
                        <remove_value name="$config" />
                    </actions>
                </cue>

                <!-- ─── Build the options menu rows ─────────────────────── -->

                <cue name="Open_Options_Menu" instantiate="true" version="1">
                    <conditions>
                        <event_cue_signalled />
                    </conditions>
                    <actions>
                        <include_actions ref="Get_Variables" />
                        <debug_text text="'ProductionStationsTab Options: Opening Options Menu'" chance="$debugChance" filter="scripts" />

                        <!-- ── Display options section ── -->
                        <run_actions ref="Add_Title_Row">
                            <param name="title" value="{1972092418, 10100}" />
                        </run_actions>
                        <run_actions ref="Add_CheckBox">
                            <param name="id" value="'showAll'" />
                            <param name="col" value="1" />
                            <param name="textColSpan" value="11" />
                            <param name="text" value="{1972092418, 10110}" />
                            <param name="data" value="@$config" />
                        </run_actions>

                        <!-- ── Filter label ── -->
                        <include_actions ref="Add_Empty_Row" />
                        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" param="table[$selectable = false]" />
                        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text"
                            param="table[
                $col = 1,
                $colSpan = 12,
                $halign = 'left',
                $text = {1972092418, 10120},
              ]" />

                        <!-- ── Intermediate production issues (middle-stage modules) ── -->
                        <include_actions ref="Add_Empty_Row" />
                        <run_actions ref="Add_Title_Row">
                            <param name="title" value="{1972092418, 10300}" />
                        </run_actions>
                        <run_actions ref="Add_CheckBox">
                            <param name="id" value="'filterIntNoRes'" />
                            <param name="col" value="1" />
                            <param name="textColSpan" value="11" />
                            <param name="text" value="{1001, 8431}" />
                            <param name="data" value="@$config" />
                        </run_actions>
                        <run_actions ref="Add_CheckBox">
                            <param name="id" value="'filterIntWaitStore'" />
                            <param name="col" value="1" />
                            <param name="textColSpan" value="11" />
                            <param name="text" value="{1001, 8432}" />
                            <param name="data" value="@$config" />
                        </run_actions>

                        <!-- ── Production issues (final-product modules) ── -->
                        <include_actions ref="Add_Empty_Row" />
                        <run_actions ref="Add_Title_Row">
                            <param name="title" value="{1972092418, 10400}" />
                        </run_actions>
                        <run_actions ref="Add_CheckBox">
                            <param name="id" value="'filterProdNoRes'" />
                            <param name="col" value="1" />
                            <param name="textColSpan" value="11" />
                            <param name="text" value="{1001, 8431}" />
                            <param name="data" value="@$config" />
                        </run_actions>
                        <run_actions ref="Add_CheckBox">
                            <param name="id" value="'filterProdWaitStore'" />
                            <param name="col" value="1" />
                            <param name="textColSpan" value="11" />
                            <param name="text" value="{1001, 8432}" />
                            <param name="data" value="@$config" />
                        </run_actions>

                        <remove_value name="$config" />
                    </actions>
                </cue>

                <!-- ─── Checkbox change handler ─────────────────────────── -->

                <cue name="Handle_Checkbox_Changed" instantiate="true" version="1">
                    <conditions>
                        <event_cue_signalled />
                    </conditions>
                    <actions>
                        <include_actions ref="Get_Variables" />
                        <debug_text text="'ProductionStationsTab Options: Checkbox %s changed to %s' . [event.param.$id, event.param.$checked]" chance="$debugChance" filter="scripts" />
                        <set_value name="$valueId" exact="event.param.$echo.$valueId" />
                        <do_if value="@$valueId != ''">
                            <set_value name="$config.{@$valueId}" exact="event.param.$checked == 1" />
                        </do_if>
                        <raise_lua_event name="'ProductionStationsTab.ConfigChanged'" />
                        <remove_value name="$valueId" />
                        <remove_value name="$config" />
                    </actions>
                </cue>

                <!-- ─── Helper libraries ────────────────────────────────── -->

                <library name="Add_Title_Row" purpose="run_actions">
                    <params>
                        <param name="title" />
                    </params>
                    <actions>
                        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" param="table[$selectable = false]" />
                        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text"
                            param="table[
                $col = 1,
                $colSpan = 12,
                $fontsize = 'Helper.titleFontSize',
                $titleColor = 'Color.text_normal',
                $halign = 'center',
                $text = $title,
              ]" />
                        <include_actions ref="Add_Empty_Row" />
                    </actions>
                </library>

                <library name="Add_Empty_Row" purpose="include_actions">
                    <actions>
                        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" param="table[$selectable = false]" />
                        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text"
                            param="table[
                $col = 1,
                $colSpan = 12,
                $height = 'Helper.borderSize',
                $fontsize = 'Helper.borderSize',
              ]" />
                    </actions>
                </library>

                <library name="Add_CheckBox" purpose="run_actions">
                    <params>
                        <param name="id" />
                        <param name="col" default="1" />
                        <param name="textColSpan" default="11" />
                        <param name="text" default="''" />
                        <param name="data" />
                    </params>
                    <actions>
                        <do_if value="@$id != null and $col? and $textColSpan? and @$text != null and @$data != null">
                            <do_if value="@$col == 1">
                                <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" />
                            </do_if>
                            <set_value name="$valueId" exact="'$%s' . [@$id]" />
                            <signal_cue_instantly cue="md.Simple_Menu_API.Make_CheckBox"
                                param="table[
                  $id      = 'ProductionStationsTab_CheckBox_%s' . [@$id],
                  $checked = @$data.{@$valueId} == true,
                  $col     = @$col,
                  $colSpan = 1,
                  $x       = 20,
                  $width   = 'Helper.standardButtonHeight',
                  $height  = 'Helper.standardButtonHeight',
                  $onClick = Handle_Checkbox_Changed,
                  $echo    = table[
                    $valueId = @$valueId
                  ],
                ]" />
                            <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text"
                                param="table[
                  $col     = @$col + 1,
                  $colSpan = @$textColSpan,
                  $halign  = 'left',
                  $text    = @$text,
                ]" />
                            <remove_value name="$valueId" />
                        </do_if>
                    </actions>
                </library>

            </cues>
        </cue>

    </cues>
</mdscript>